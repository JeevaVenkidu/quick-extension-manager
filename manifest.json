{
  "manifest_version": 3,
  "name": "Quick Extension Manager",
  "version": "1.0.0",
  "description": "Turn extensions on and off quickly without going to the Chrome extensions page.",
  "permissions": ["management"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick Extension Manager",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
